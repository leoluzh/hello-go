# ============================================================
#  hello-go — variáveis de ambiente
#  Copie este arquivo para .env e preencha os valores:
#  cp .env.example .env
# ============================================================

# ------------------------------------------------------------
# Aplicação
# ------------------------------------------------------------
APP_NAME=hello-go
PORT=8080

# ------------------------------------------------------------
# Docker Hub
# ------------------------------------------------------------
DOCKERHUB_USER=meuusuario
DOCKERHUB_PASS=meu-access-token   # gere em: https://hub.docker.com/settings/security
TAG=latest

# ------------------------------------------------------------
# GitHub Container Registry (GHCR)
# ------------------------------------------------------------
GITHUB_USER=meuusuario
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx   # gere em: https://github.com/settings/tokens
                                        # escopos necessários: write:packages, read:packages

# ------------------------------------------------------------
# Runtime de container (docker ou podman)
# Deixe em branco para detecção automática
# ------------------------------------------------------------
RUNTIME=
